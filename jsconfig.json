{
    "compilerOptions": {
        "checkJs": true,
        "strict": true,
        "strictNullChecks": false,
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2020", "DOM", "DOM.Iterable"],
        "noEmit": true,
        "skipLibCheck": true
    },
    "include": ["*.js", "types/**/*.d.ts"]
}
