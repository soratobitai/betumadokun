{
    "manifest_version": 3,
    "name": "別窓くん（ニコ生 多窓サポート）",
    "description": "ニコニコ生放送の番組を別窓で開くためのChrome機能拡張です。",
    "version": "1.8.1",
    "author": "MynicoTools",
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "content_scripts": [
        {
            "matches": [
                "https://live.nicovideo.jp/*",
                "https://blog.nicovideo.jp/*",
                "https://www.nicovideo.jp/*",
                "https://nicovideo.jp/*",
                "https://www.chikuwachan.com/*",
                "https://chikuwachan.com/*"
            ],
            "js": [
                "main.js"
            ],
            "css": [
                "main.css"
            ],
            "run_at": "document_start",
            "all_frames": true
        },
        {
            "matches": [
                "https://live.nicovideo.jp/watch/*"
            ],
            "js": [
                "watch.js"
            ],
            "css": [
                "watch.css"
            ],
            "run_at": "document_start"
        }
    ],
    "web_accessible_resources": [
        {
            "resources": [
                "images/*.png",
                "main.css"
            ],
            "matches": [
                "https://*/*"
            ]
        }
    ],
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "https://live.nicovideo.jp/*"
    ],
    "background": {
        "service_worker": "background.js"
    }
}